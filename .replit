# Run command for Replit
run = "npm run dev"

# Language
language = "nodejs"
modules = ["nodejs-20"]

# Environment variables
[env]
PORT = "3000"
MONGO_URI = "mongodb+srv://BATTERY:BT123456789@anikage.kcccomb.mongodb.net/batteryDB?retryWrites=true&w=majority"
DELETE_PASS = "BT@12345"

# Workflows (optional, Replit UI run button)
[workflows]
runButton = "npm run dev"

[[workflows.workflow]]
name = "Install & Start"
mode = "sequential"
author = 33309924

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

# Agent expert mode
[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 80
